# @ethora/chat-component — example environment configuration.
#
# Copy this file to `.env.local` (which is gitignored) and fill in the
# values for your Ethora app. `src/utils/runtimeHostConfig.ts` reads
# these via `import.meta.env` and surfaces them through `src/config.ts`.
# `src/App.tsx`'s APP_CHAT_BASE_CONFIG defaults to those values.
#
# `@ethora/setup` writes this file automatically — see
# https://github.com/dappros/ethora-setup for the CLI flow.

# Your Ethora app ID (24-char hex), from POST /apps on your Ethora backend.
VITE_APP_ID=

# Your Ethora app token (the "JWT eyJ..." string from POST /apps).
# Sent as the Authorization header on /users/login-with-email and other
# unauthenticated endpoints — must match the app the user is logging
# into, otherwise the API rejects requests as 401.
VITE_APP_TOKEN=

# API base URL — e.g. https://api.chat.ethora.com/v1 for Ethora Cloud,
# or your self-hosted Ethora API.
VITE_API=

# Your custom domain name (the app's "name" you registered).
VITE_DOMAIN_NAME=

# Web app host (used to build links back to the chat web app).
VITE_WEB_DOMAIN=

# XMPP host — the WebSocket endpoint serves on the default 443 port,
# do NOT include `:5443`.
VITE_XMPP_HOST=

# XMPP conference / MUC service domain.
VITE_XMPP_SERVICE=

# Full XMPP WebSocket URL (preferred over deriving from VITE_XMPP_HOST
# when your reverse proxy serves the WS at a non-default path).
VITE_APP_XMPP_SERVICE=
