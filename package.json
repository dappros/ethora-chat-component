{
  "name": "@ethora/chat-component",
  "version": "26.5.7",
  "type": "module",
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "files": [
    "dist",
    "public/firebase-messaging-sw.js",
    "scripts/init-push.js"
  ],
  "bin": {
    "ethora-chat": "./scripts/init-push.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "sync:lib": "node ./scripts/sync-lib.mjs",
    "build:lib": "npm run sync:lib && tsc --p ./tsconfig-build.json && vite build",
    "prepare": "npm run build && npm run build:lib",
    "lint": "eslint . --quiet --report-unused-disable-directives",
    "lint:full": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "lint:fix": "eslint . --fix && prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@emoji-mart/data": "^1.2.1",
    "@emoji-mart/react": "^1.1.1",
    "@reduxjs/toolkit": "^2.8.2",
    "@types/styled-components": "^5.1.34",
    "@xmpp/client": "^0.13.6",
    "axios": "^1.10.0",
    "emoji-mart": "^5.6.0",
    "firebase": "^11.9.1",
    "js-sha256": "^0.11.1",
    "ltx": "^3.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.0.16",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.6.2",
    "react-use-measure": "^2.1.7",
    "redux": "^5.0.1",
    "redux-persist": "^6.0.0",
    "redux-persist-transform-encrypt": "^5.1.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "styled-components": "^6.1.19",
    "uuid": "^11.1.0",
    "wavesurfer.js": "^7.9.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.0.3",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/xmpp__client": "^0.13.3",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^24.1.0",
    "prettier": "3.6.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.0.0"
  },
  "overrides": {
    "csstype": "3.1.3"
  },
  "description": "1. npm create vite@latest 2. select name of project, select type (react/js) 3. cd project-name 4. npm i 5. npm i @ethora/chat-component 6. go to file src/App.tsx and replace it with this code",
  "directories": {
    "lib": "lib"
  },
  "author": "Ethora",
  "license": "AGPL",
  "keywords": [
    "chat",
    "messaging",
    "react",
